{
  "name": "core-api",
  "version": "0.1.0",
  "description": "A tiny, hyperscalable API starter — Bun + Hono + Drizzle/Postgres. Auth, API keys, multi-tenant orgs, realtime rooms, webhooks, OpenAPI.",
  "license": "MIT",
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@scalar/hono-api-reference": "^0.5.172",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "hono-openapi": "^0.4.6",
    "nanoid": "^5.0.9",
    "otpauth": "^9.3.6",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "zod": "^3.24.1",
    "zod-openapi": "^4.2.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/qrcode": "^1.5.5",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.7.2"
  }
}
