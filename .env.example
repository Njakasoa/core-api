# ── Core ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Comma-separated allowed origins for CORS (use * only in dev)
CORS_ORIGINS=*

# ── Database (Postgres) ────────────────────────────────
# Local dev via docker-compose: postgres://core:core@localhost:5432/core_api
DATABASE_URL=postgres://core:core@localhost:5432/core_api

# ── Auth ───────────────────────────────────────────────
# 32+ char secret used to sign JWT access tokens. CHANGE THIS.
JWT_SECRET=change-me-to-a-long-random-secret-string-min-32
# Access token TTL (seconds) and refresh token TTL (seconds)
ACCESS_TTL=900
REFRESH_TTL=2592000

# ── Rate limiting ──────────────────────────────────────
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=120

# ── Webhooks ───────────────────────────────────────────
# Max delivery attempts before a webhook event is marked failed
WEBHOOK_MAX_ATTEMPTS=5
